exports[`install-templates > Claude Code + Docker matches snapshot 1`] = `
{
  "body": "claude mcp add kxta -s user \\
  -e KONTEXTA_DATA_DIR=/home/user/kontexta-data \\
  -- docker run --rm -i -v /home/user/kontexta-data:/app/data safiyu/kontexta:1.0.0 mcp",
