  "kind": "shell",
  "notes": [],
}
`;

exports[`install-templates > Claude Desktop + npm matches snapshot 1`] = `
{
  "body": "{
  "mcpServers": {
    "kxta": {
      "command": "npx",
      "args": [
        "-y",
        "kontexta-mcp"
      ],
      "env": {
        "KONTEXTA_DATA_DIR": "/home/user/kontexta-data"
      }
    }
  }
}",
  "configPath": "macOS: ~/Library/Application Support/Claude/claude_desktop_config.json
Windows: %APPDATA%\\Claude\\claude_desktop_config.json",
  "kind": "json",
  "notes": [],
}
`;
